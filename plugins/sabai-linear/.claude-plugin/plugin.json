{
  "name": "sabai-linear",
  "description": "Product Manager assistant with Linear integration. Create tickets, manage backlog, generate PRDs, and more.",
  "version": "1.6.0",
  "author": {
    "name": "Sabai Team"
  },
  "keywords": ["linear", "project-management", "tickets", "backlog", "prd"],
  "skills": "./skills/",
  "commands": "./commands/",
  "mcpServers": {
    "linear": {
      "command": "bash",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/startup.sh"],
      "env": {
        "LINEAR_API_KEY": "${LINEAR_API_KEY}"
      }
    }
  }
}
