{
  "name": "sabai-recall",
  "description": "Meeting bot automation with Recall.ai. Create bots to join and record meetings, access recordings, transcripts, and participant data.",
  "version": "1.4.0",
  "author": {
    "name": "Sabai Team"
  },
  "keywords": ["recall", "meetings", "recording", "transcription", "bot", "video"],
  "commands": "./commands/",
  "mcpServers": {
    "sabai-recall": {
      "command": "bash",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/startup.sh"],
      "env": {
        "RECALL_API_KEY": "${RECALL_API_KEY}",
        "RECALL_REGION": "${RECALL_REGION:-us-west-2}"
      }
    }
  }
}
