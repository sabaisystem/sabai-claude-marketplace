{
  "name": "sabai-gmail",
  "description": "Gmail assistant for email composition, inbox management, templates, and follow-up tracking.",
  "version": "1.4.0",
  "author": {
    "name": "Sabai Team"
  },
  "keywords": ["gmail", "email", "inbox", "google", "communication"],
  "skills": "./skills/",
  "commands": "./commands/",
  "mcpServers": {
    "gmail": {
      "command": "bash",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/startup.sh"],
      "env": {
        "GOOGLE_CREDENTIALS": "${CLAUDE_PLUGIN_ROOT}/mcp/config/credentials.json",
        "GOOGLE_TOKEN": "${CLAUDE_PLUGIN_ROOT}/mcp/config/token.json"
      }
    }
  }
}
